[WELT.language.switch]
version = 1.1
type    = "welt-language-switch"

switch.bind = "WELT.language.buttons.final"

switch.map = {
  DE  = "WELT.language.DE",
  TR  = "WELT.language.TR",
  EN  = "WELT.language.EN",

  # frei wählbare Slots
  DA  = "WELT.language.du",
  NE  = "WELT.language.er",
  BEN = "WELT.language.ich"
}

switch.mode   = ["manual","auto","fallback"]
switch.output = "WELT.language.switch.final"
switch.state  = "active"
