[WELT.language.switch]
version = 1.0
type    = "welt-language-switch"

switch.bind = "WELT.language.buttons.final"

switch.map = {
  DE  = "WELT.language.DE",
  TR  = "WELT.language.TR",
  EN  = "WELT.language.EN",
  DA  = "WELT.language.DA",
  NE  = "WELT.language.NE",
  BEN = "WELT.language.custom"
}

switch.mode = ["manual","auto","fallback"]
switch.output = "WELT.language.switch.final"
switch.state  = "active"
