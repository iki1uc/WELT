[WELT.language.buttons]
version = 1.0
type    = "welt-language-ui"
zero    = 0

lang.fixed = ["DE","TR","EN"]
lang.flex  = ["DA","NE","BEN"]

lang.labels = {
  DE  = "Deutsch",
  TR  = "Türkçe",
  EN  = "English",
  DA  = "Dansk",
  NE  = "Nederlands",
  BEN = "Benutzerwahl"
}

lang.mode = ["switch","manual","auto","fallback"]

lang.output = "WELT.language.buttons.final"
lang.state  = "active"
